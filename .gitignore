# Data & artifacts (keep on disk, not in git)
# Anchored to the repo-root data/ ONLY (leading slash), so this no longer also
# ignores the src/data/ source package. Raw inputs under data/ stay ignored, but
# the frozen reproducibility artifacts (data/frozen/) are tracked.
/data/*
!/data/frozen/
models/*.joblib
models/backup_pre_alpha099_20260526/
predictions/*.csv
outputs/*
!outputs/shap/
outputs/shap/*
!outputs/shap/*.png
!outputs/shap/*.csv
cache/
logs/

# Legacy (archive versions, keep v8 baseline and toy data)
legacy/archive/
legacy/*.py
!legacy/atm_xgboost_forecast_v8.py
!legacy/optimization_phase_toy_data.py

